#!/bin/bash
# Pre-commit hook for web app

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}🔍 Running local code review checks...${NC}"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
CODE_FILES=$(echo "$STAGED_FILES" | grep -E '\.(js|jsx)$' || true)

if [ -z "$CODE_FILES" ]; then
    echo -e "${GREEN}✅ No code files to review${NC}"
    exit 0
fi

echo -e "${YELLOW}📝 Files to review:${NC}"
echo "$CODE_FILES" | sed 's/^/  /'

# Basic linting check
echo -e "\n${YELLOW}⚡ Running basic code checks...${NC}"

# Check for console.log (should use proper logging)
if grep -r "console\.log" $CODE_FILES > /dev/null; then
    echo -e "${YELLOW}⚠️  console.log found - consider using logger${NC}"
fi

# Check for var (use let/const)
if grep -r "^\s*var " $CODE_FILES > /dev/null 2>&1; then
    echo -e "${YELLOW}⚠️  'var' keyword found - use 'let' or 'const' instead${NC}"
fi

# Check for alert() calls
if grep -r "alert\(" $CODE_FILES > /dev/null; then
    echo -e "${RED}❌ alert() found - use proper error handling${NC}"
    exit 1
fi

echo -e "\n${GREEN}✅ Pre-commit checks passed!${NC}"
echo -e "${YELLOW}💡 Tip: Use \`/code-review\` in Copilot for detailed analysis${NC}"
exit 0
